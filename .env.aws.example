# Example for .env.aws (AWS fallback env). DO NOT COMMIT REAL SECRETS.
#
# The real .env.aws file is gitignored (see .gitignore) and is only a FALLBACK.
# At runtime, secrets are sourced primarily from AWS SSM Parameter Store by
# scripts/aws/render_runtime_env.sh. Prefer SSM / GitHub App auth over inline
# values here. Never paste a live token (gho_/ghp_/ghs_/github_pat_) into this
# file or any tracked file.

# --- Non-secret config ---
ENVIRONMENT=aws
NODE_ENV=production
AWS_REGION=ap-southeast-1

# --- Secrets: leave blank here; provide via AWS SSM at runtime ---
# GitHub auth is preferred via GitHub App (GITHUB_APP_ID / GITHUB_APP_INSTALLATION_ID
# / GITHUB_APP_PRIVATE_KEY_B64). GITHUB_TOKEN is a legacy PAT escape hatch only.
# SSM: /automated-trading-platform/prod/github_token
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_B64=

# Other runtime secrets are also sourced from SSM; do not inline real values.
# See docs/runbooks/secrets_runtime_env.md
