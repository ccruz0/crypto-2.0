# Template for secrets/runtime.env (rendered by scripts/aws/render_runtime_env.sh).
# Do NOT commit real values. Copy to runtime.env only via the render script.
TELEGRAM_BOT_TOKEN=
<REDACTED_TELEGRAM_TOKEN>
ADMIN_ACTIONS_KEY=
DIAGNOSTICS_API_KEY=
# Required for protected API endpoints (POST /api/engine/run-once, etc.). Set to a secret token; backend reads via ATP_API_KEY.
ATP_API_KEY=
ENVIRONMENT=aws
RUN_TELEGRAM=true
# Telegram notification verbosity: minimal (default) = fewer messages; verbose = more status updates
# TELEGRAM_NOTIFICATION_MODE=minimal
# OpenClaw gateway token (same token used by OpenClaw gateway auth)
OPENCLAW_API_TOKEN=
OPENCLAW_API_URL=http://172.31.3.214:8080
# Optional: cheap-first model chain for main tasks; verification uses cheaper model (cost optimization)
# OPENCLAW_MODEL_CHAIN=openai/gpt-4o-mini,anthropic/claude-3-5-haiku-20241022
# Verification-only chain: use cheap model for PASS/FAIL review (saves cost vs main chain)
OPENCLAW_VERIFICATION_PRIMARY_MODEL=openai/gpt-4o-mini
# ATP_SOLUTION_VERIFICATION_ENABLED=true (default); set false to skip verification LLM call per task
# ATP_SOLUTION_VERIFICATION_ENABLED=false

# Task-type routing: doc/monitoring use cheap chain; bug tasks use main chain. (enabled)
OPENCLAW_CHEAP_TASK_TYPES=doc,documentation,monitoring,triage
OPENCLAW_CHEAP_MODEL_CHAIN=openai/gpt-4o-mini
# Optional: cap Notion task details/title fields in prompts (default 8000 chars)
# OPENCLAW_TASK_DETAILS_MAX_CHARS=8000
# Output cap (OpenResponses API; scripts/aws/render_runtime_env.sh appends OPENCLAW_MAX_OUTPUT_TOKENS=8192 when rendering PROD)
# OPENCLAW_MAX_OUTPUT_TOKENS=8192

# Notion (AI Task System). Rendered from SSM (/automated-trading-platform/prod/notion/api_key, task_db) or .env.aws.
# Set NOTION_API_KEY and NOTION_TASK_DB in .env.aws if not in SSM (e.g. LAB).

# Agent scheduler: higher interval = fewer task pickups and LLM calls (cost). Default 300.
# AGENT_SCHEDULER_INTERVAL_SECONDS=600

# GitHub webhook secret for /api/github/actions (from repo Settings → Webhooks → Add webhook → Secret)
GITHUB_WEBHOOK_SECRET=

# OpenClaw Tavily web search (optional). Set via: bash scripts/setup_tavily_key.sh
# TAVILY_API_KEY=
# SEARCH_PROVIDER=tavily

# Price stream WebSocket for dashboard (/api/ws/prices). Optional.
# ENABLE_WS_PRICES=true
# PRICE_STREAM_INTERVAL_S=10

# Cursor Execution Bridge (Phase 1). See docs/architecture/CURSOR_EXECUTION_BRIDGE_DESIGN.md
# Production (approval required; no scheduler auto-run — use Telegram "Run Cursor Bridge" or API after patch_approved):
CURSOR_BRIDGE_ENABLED=true
CURSOR_BRIDGE_REQUIRE_APPROVAL=true
CURSOR_BRIDGE_AUTO_IN_ADVANCE=false
CURSOR_CLI_PATH=cursor
ATP_STAGING_ROOT=/tmp/atp-staging
# Optional: CURSOR_CLI_TIMEOUT=300
# CURSOR_BRIDGE_TEST_TIMEOUT=120
# Scheduler auto-bridge (off by default): set CURSOR_BRIDGE_AUTO_IN_ADVANCE=true to opt in
# For PR creation: GITHUB_TOKEN (repo scope), GITHUB_REPOSITORY (owner/repo)

# ATP SSM runner (for /api/agent/run-atp-command). Backend needs AWS credentials to call SSM.
# Option A: Instance IAM role (if container can reach 169.254.169.254 metadata). Often fails in Docker.
# Option B: Explicit credentials from SSM. Store in Parameter Store and render_runtime_env will inject:
#   /automated-trading-platform/prod/aws_access_key_id
#   /automated-trading-platform/prod/aws_secret_access_key
# IAM user/role needs: ssm:SendCommand, ssm:GetCommandInvocation, ssm:ListCommands.
# ATP_SSM_INSTANCE_ID=i-087953603011543c5
# ATP_SSM_REGION=ap-southeast-1
# ATP_PROJECT_PATH=/home/ubuntu/crypto-2.0
# LAB SSM (for /api/agent/run-lab-command). Same AWS creds; IAM must allow SendCommand to LAB instance.
# LAB_SSM_INSTANCE_ID=i-0d82c172235770a0d
# LAB_SSM_REGION=ap-southeast-1
