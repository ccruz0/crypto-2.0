# Template for secrets/runtime.env (rendered by scripts/aws/render_runtime_env.sh).
# Do NOT commit real values. Copy to runtime.env only via the render script.
TELEGRAM_BOT_TOKEN=
<REDACTED_TELEGRAM_TOKEN>
ADMIN_ACTIONS_KEY=
DIAGNOSTICS_API_KEY=
# Required for protected API endpoints (POST /api/engine/run-once, etc.). Set to a secret token; backend reads via ATP_API_KEY.
ATP_API_KEY=
ENVIRONMENT=aws
RUN_TELEGRAM=true
# Telegram notification verbosity: minimal (default) = fewer messages; verbose = more status updates
# TELEGRAM_NOTIFICATION_MODE=minimal
# OpenClaw gateway token (same token used by OpenClaw gateway auth)
OPENCLAW_API_TOKEN=
OPENCLAW_API_URL=http://172.31.3.214:8080
# Optional: cheap-first model chain for main tasks; verification can use cheaper model (see .env.example)
# OPENCLAW_MODEL_CHAIN=openai/gpt-4o-mini,anthropic/claude-3-5-haiku-20241022
# OPENCLAW_VERIFICATION_PRIMARY_MODEL=openai/gpt-4o-mini
# ATP_SOLUTION_VERIFICATION_ENABLED=true

# GitHub webhook secret for /api/github/actions (from repo Settings → Webhooks → Add webhook → Secret)
GITHUB_WEBHOOK_SECRET=

# OpenClaw Tavily web search (optional). Set via: bash scripts/setup_tavily_key.sh
# TAVILY_API_KEY=
# SEARCH_PROVIDER=tavily

# Price stream WebSocket for dashboard (/api/ws/prices). Optional.
# ENABLE_WS_PRICES=true
# PRICE_STREAM_INTERVAL_S=10

# Cursor Execution Bridge (Phase 1). See docs/architecture/CURSOR_EXECUTION_BRIDGE_DESIGN.md
# CURSOR_BRIDGE_ENABLED=false
# ATP_STAGING_ROOT=/tmp/atp-staging
# CURSOR_CLI_PATH=cursor
# CURSOR_CLI_TIMEOUT=300
# CURSOR_BRIDGE_TEST_TIMEOUT=120
# For PR creation: GITHUB_TOKEN (repo scope), GITHUB_REPOSITORY (owner/repo)
# CURSOR_BRIDGE_AUTO_IN_ADVANCE=true — run bridge automatically in advance_ready_for_patch_task when handoff exists
