-async function fetchJarvisControlAPI<T>(endpoint: string, options?: RequestInit): Promise<T> {
-  return fetchAPI<T>(endpoint, {
-    ...options,
-    headers: {
-      ...jarvisControlAuthHeaders(),
-      ...(options?.headers ?? {}),
-    },
-  });
-}
