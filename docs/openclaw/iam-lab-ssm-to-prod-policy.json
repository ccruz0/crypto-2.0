{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SendCommandToProdOnly",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand"
      ],
      "Resource": "arn:aws:ec2:ap-southeast-1:*:instance/i-087953603011543c5"
    },
    {
      "Sid": "GetCommandOutput",
      "Effect": "Allow",
      "Action": [
        "ssm:GetCommandInvocation",
        "ssm:ListCommands",
        "ssm:ListCommandInvocations"
      ],
      "Resource": "*"
    }
  ]
}
