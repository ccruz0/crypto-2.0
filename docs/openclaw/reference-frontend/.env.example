# Optional: override WebSocket URL. Default: same-origin /openclaw/ws (prod).
# Next.js (local dev): NEXT_PUBLIC_OPENCLAW_WS_URL=ws://localhost:8081/ws
NEXT_PUBLIC_OPENCLAW_WS_URL=

# Vite: VITE_OPENCLAW_WS_URL=ws://localhost:8081/ws for local dev
VITE_OPENCLAW_WS_URL=

# Base path when served at /openclaw/ (Next.js prod build)
NEXT_PUBLIC_OPENCLAW_BASE_PATH=/openclaw

# Vite prod build
VITE_OPENCLAW_BASE_PATH=/openclaw/
