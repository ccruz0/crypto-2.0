[Unit]
Description=Jarvis task auditor (read-only)
After=network-online.target docker.service

[Service]
Type=oneshot
WorkingDirectory=@REPO_ROOT@
EnvironmentFile=-@REPO_ROOT@/secrets/runtime.env
EnvironmentFile=-@REPO_ROOT@/.env.aws
ExecStart=@PYTHON@ @REPO_ROOT@/scripts/automation/task_auditor.py
User=root

[Install]
WantedBy=multi-user.target
