# .env.lab.example — copy to .env.lab on Lab instance. Do NOT put token here.
# Token is stored in ~/secrets/openclaw_token and mounted read-only into container.
# Do NOT commit .env.lab. Do NOT use production secrets here.
# See: docs/openclaw/DEPLOYMENT.md, docs/openclaw/FINAL_SECURITY_CHECKLIST.md

# Runtime mode and origin (required by OpenClaw container)
OPENCLAW_MODE=lab
RUNTIME_ORIGIN=LOCAL

# Repo to clone and work with (HTTPS)
GIT_REPO_URL=https://github.com/ccruz0/crypto-2.0.git

# Path inside container where token file is mounted (read-only). Do NOT put token value here.
OPENCLAW_TOKEN_FILE=/run/secrets/openclaw_token

# Host path to token file (for reference; token is NOT stored in this file)
OPENCLAW_TOKEN_PATH=/home/ubuntu/secrets/openclaw_token

# OpenClaw image: use real app (ghcr.io/ccruz0/openclaw:latest) or placeholder (ghcr.io/ccruz0/crypto-2.0:openclaw)
# See docs/openclaw/BUILD_AND_PUSH_OPENCLAW_IMAGE.md and docs/runbooks/DEPLOY_REAL_OPENCLAW_APP_ON_LAB.md
OPENCLAW_IMAGE=ghcr.io/ccruz0/openclaw:latest

# Optional: branch to base work on
OPENCLAW_BASE_BRANCH=main

# Optional: log level
OPENCLAW_LOG_LEVEL=INFO

# Required when OpenClaw runs behind a reverse proxy (e.g. https://dashboard.hilovivo.com/openclaw).
OPENCLAW_ALLOWED_ORIGINS=https://dashboard.hilovivo.com,http://localhost:8080,http://127.0.0.1:8080

# Trusted proxy IPs (comma-separated). Required when behind nginx reverse proxy.
# Use the PROD instance private IP so OpenClaw treats proxied requests as local.
OPENCLAW_TRUSTED_PROXIES=172.31.32.169

# Anthropic API key — required for the agent to work.
# Get yours at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=<your-key-here>
