# .env.lab.example — copy to .env.lab on Lab instance. Do NOT put token here.
# Token is stored in ~/secrets/openclaw_token and mounted read-only into container.
# Do NOT commit .env.lab. Do NOT use production secrets here.
# See: docs/openclaw/DEPLOYMENT.md, docs/openclaw/FINAL_SECURITY_CHECKLIST.md

# Repo to clone and work with (HTTPS)
GIT_REPO_URL=https://github.com/ccruz0/crypto-2.0.git

# Host path to token file (token is NOT stored in this file)
OPENCLAW_TOKEN_PATH=/home/ubuntu/secrets/openclaw_token

# OpenClaw image (REQUIRED: replace with your image or build locally — see docs/openclaw/DEPLOYMENT.md)
OPENCLAW_IMAGE=ghcr.io/your-org/openclaw:latest

# Optional: branch to base work on
OPENCLAW_BASE_BRANCH=main

# Optional: log level
OPENCLAW_LOG_LEVEL=INFO
