# Backend API port (default: 8002)
# API_PORT=8002
FRONTEND_PORT=3000

# Database
DATABASE_URL=postgresql://trader:traderpass@db:5432/atp

# Security / runtime
SECRET_KEY=change-me
ENVIRONMENT=local
APP_ENV=local
RUN_TELEGRAM=false
# Optional: system context for Notion tasks (notion_tasks.py)
# SERVICE_NAME=trading-engine
# APP_ENV=production
RUNTIME_ORIGIN=LOCAL
LIVE_TRADING=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Exchanges
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Optional override for Crypto.com REST credentials
EXCHANGE_CUSTOM_BASE_URL=
EXCHANGE_CUSTOM_API_KEY=
EXCHANGE_CUSTOM_API_SECRET=

# Redis / caching
REDIS_URL=redis://localhost:6379

# Proxy
USE_CRYPTO_PROXY=false
CRYPTO_PROXY_URL=http://127.0.0.1:9000
CRYPTO_PROXY_TOKEN=CRYPTO_PROXY_SECURE_TOKEN_2024

# Notion (AI Task System — optional; for create_notion_task)
# NOTION_API_KEY=secret_...
# NOTION_TASK_DB=<database_id>
# NOTION_TASK_COOLDOWN_SECONDS=600
# AGENT_SCHEDULER_INTERVAL_SECONDS=300

# OpenClaw integration (AI agent execution for Notion tasks — optional)
# OPENCLAW_API_URL=http://172.31.3.214:8080
# OPENCLAW_API_TOKEN=<gateway-token>
# OPENCLAW_TIMEOUT_SECONDS=120
