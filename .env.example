# Backend API port (default: 8002)
# API_PORT=8002
FRONTEND_PORT=3000

# Database
DATABASE_URL=postgresql://trader:traderpass@db:5432/atp

# Security / runtime
SECRET_KEY=change-me
ENVIRONMENT=local
APP_ENV=local
RUN_TELEGRAM=false

# Health: market data staleness threshold (minutes). Default 30; production recommended 15.
# Invalid or out-of-range values fall back to 30. See docs/MARKET_UPDATER_HARDENING_PLAN.md.
# HEALTH_STALE_MARKET_MINUTES=30
# Optional: system context for Notion tasks (notion_tasks.py)
# SERVICE_NAME=trading-engine
# APP_ENV=production
RUNTIME_ORIGIN=LOCAL
LIVE_TRADING=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Notification verbosity: minimal (default) = fewer messages; verbose = more status updates
# TELEGRAM_NOTIFICATION_MODE=minimal

# Exchanges
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Optional override for Crypto.com REST credentials
EXCHANGE_CUSTOM_BASE_URL=
EXCHANGE_CUSTOM_API_KEY=
EXCHANGE_CUSTOM_API_SECRET=

# Redis / caching
REDIS_URL=redis://localhost:6379

# Proxy
USE_CRYPTO_PROXY=false
CRYPTO_PROXY_URL=http://127.0.0.1:9000
CRYPTO_PROXY_TOKEN=CRYPTO_PROXY_SECURE_TOKEN_2024

# Notion (AI Task System — optional; for create_notion_task and agent scheduler)
# NOTION_API_KEY=secret_...
# NOTION_TASK_DB=eb90cfa139f94724a8b476315908510a   # AI Task System database ID (not the task page ID)
# NOTION_TASK_COOLDOWN_SECONDS=600
# AGENT_SCHEDULER_INTERVAL_SECONDS=300

# OpenClaw integration (AI agent execution for Notion tasks — optional)
# OPENCLAW_API_URL=http://172.31.3.214:8080
# OPENCLAW_API_TOKEN=<gateway-token>
# OPENCLAW_TIMEOUT_SECONDS=120
# Model fallback: cheap-first. See docs/OPENCLAW_LOW_COST_MODEL_FALLBACK_STRATEGY.md
# OPENCLAW_CHEAP_FIRST_MODE=true
# OPENCLAW_MODEL_CHAIN=openai/gpt-4o-mini,anthropic/claude-3-5-haiku-20241022,anthropic/claude-3-5-sonnet-20241022
# Or: OPENCLAW_PRIMARY_MODEL=openai/gpt-4o-mini
#     OPENCLAW_FALLBACK_MODEL_1=anthropic/claude-3-5-haiku-20241022
#     OPENCLAW_FALLBACK_MODEL_2=anthropic/claude-3-5-sonnet-20241022
# Verification (PASS/FAIL review): use cheaper model; if unset, uses main chain. Saves cost per task.
# OPENCLAW_VERIFICATION_PRIMARY_MODEL=openai/gpt-4o-mini
# OPENCLAW_VERIFICATION_MODEL_CHAIN=openai/gpt-4o-mini
# OPENCLAW_VERIFICATION_MAX_CHARS=8000
# Solution verification: set to false to skip verification LLM call per task (saves one call per task).
# ATP_SOLUTION_VERIFICATION_ENABLED=true
