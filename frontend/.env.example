# Frontend development port (single source of truth)
# Copy this file to .env.local and customize as needed.
FRONTEND_PORT=3001
FRONTEND_URL=http://localhost:3001

# Backend API URL for dev proxy (Next.js rewrites)
# Default: http://localhost:8002
BACKEND_URL=http://localhost:8002

# Optional: full WebSocket URL for /api/ws/prices (defaults to same-origin wss:// on HTTPS)
# NEXT_PUBLIC_WS_PRICES_URL=ws://localhost:8002/api/ws/prices
# Disable client price WebSocket: NEXT_PUBLIC_ENABLE_PRICE_WS=false
